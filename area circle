import java.util.*;
public class areacircle {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.println("enter the radius:");
        float r=sc.nextFloat();
        double pi=3.14;
        double area=pi*r*r;
        System.out.println("area circle ="+area);
        sc.close();
    }
}
