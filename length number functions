import java.util.*;
public class lengthnumberfunctions {
    public static int leng(int n,int count){
        while(n>0){
            int digit=n%10;
            count+=1;
            n/=10;
        }
        return count;
    }
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.println("enter the number:");
        int n=sc.nextInt();
        int count=0;
        System.out.println("length number ="+leng(n, count));
        sc.close();
    }
}
